pragma language_version >= 0.22;

// =============================================================================
//  SECURE PATTERN — witness-derived identity
// =============================================================================
//  Each instance holds a single 32-byte secret in private state. Caller
//  identity is derived INSIDE the circuit from that secret via domain-separated
//  `persistentHash` (`deriveUserPublicKey` / `deriveAdminPublicKey`), so a
//  caller can only act as the identity they hold the secret for. `ownPublicKey()`
//  is intentionally NOT used for authorization — it is prover-supplied and
//  bypassable. The admin is pinned at deploy: the deployer's derived admin key
//  is frozen into `contractAdmin`. Only these safe wrappers (which compute the
//  caller from the witness) are exported — never the module's
//  identity-parameterized circuits, which would let a caller pass an arbitrary
//  identity and defeat the protection.
// =============================================================================

import CompactStandardLibrary;

import "../modules/token/Nft";

// Re-export identity types and pure derivations so the TypeScript layer can
// compute public keys off-chain (e.g. to look up balances/owners by key).
export { UserSecretKey, UserPublicKey, AdminPublicKey };

export { deriveUserPublicKey, deriveAdminPublicKey };

// Export only the read-only views from the Nft module. The module's
// identity-parameterized mutating circuits (approve/setApprovalForAll/
// transferFrom/mint/burn) are deliberately NOT re-exported — exposing them
// would let a caller pass any `caller` identity. Instead, the safe wrappers
// below compute the caller from the witness secret.
export { balanceOf, ownerOf, getApproved, isApprovedForAll, tokenExists };

// The witness: each prover supplies their own 32-byte secret from private state.
witness getUserSecret(): UserSecretKey;

// The admin's derived public key, pinned at deploy time.
export ledger contractAdmin: AdminPublicKey;

// Pin the admin role to the deployer's derived admin key.
constructor() {
  contractAdmin = disclose(deriveAdminPublicKey(getUserSecret()));
}

// Transfer one of YOUR tokens to `to`. The caller is derived from the witness
// secret and is used as both the proven identity and the `from` account.
export circuit transfer(to: UserPublicKey, tokenId: Uint<64>): [] {
  assert(tokenId != default<Uint<64>>, "Token ID cannot be empty.");
  // Disclose the derived caller identity: it becomes the owner/from key for
  // ledger map operations, so its value is necessarily public on-chain.
  const caller = disclose(deriveUserPublicKey(getUserSecret()));
  transferFrom(caller, caller, to, tokenId);
}

// Transfer a token out of `fromAccount` to `to`. The caller is derived from the
// witness secret; the module asserts the caller is the owner or authorized.
export circuit transferFromAuthorized(
                 fromAccount: UserPublicKey,
                 to: UserPublicKey,
                 tokenId: Uint<64>
                 ): [] {
  const caller = disclose(deriveUserPublicKey(getUserSecret()));
  transferFrom(caller, fromAccount, to, tokenId);
}

// Approve `to` to transfer `tokenId`. Caller derived from the witness secret.
export circuit approve(to: UserPublicKey, tokenId: Uint<64>): [] {
  const caller = disclose(deriveUserPublicKey(getUserSecret()));
  approve(caller, to, tokenId);
}

// Set or unset `operator` as an operator for all of the caller's tokens.
// Caller derived from the witness secret.
export circuit setApprovalForAll(operator: UserPublicKey, approved: Boolean): [] {
  const caller = disclose(deriveUserPublicKey(getUserSecret()));
  setApprovalForAll(caller, operator, approved);
}

// Only the pinned admin can mint. The caller must prove they hold the admin
// secret whose derived admin key equals `contractAdmin`.
export circuit mintAdmin(to: UserPublicKey, tokenId: Uint<64>): [] {
  assert(contractAdmin == deriveAdminPublicKey(getUserSecret()), "Not authorized to mint.");
  mint(to, tokenId);
}

// Only the pinned admin can burn.
export circuit burnAdmin(tokenId: Uint<64>): [] {
  assert(contractAdmin == deriveAdminPublicKey(getUserSecret()), "Not authorized to burn.");
  const owner = ownerOf(tokenId);
  burn(owner, tokenId);
}
