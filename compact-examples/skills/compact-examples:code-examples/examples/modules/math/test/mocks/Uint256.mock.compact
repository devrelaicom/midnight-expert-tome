pragma language_version >= 0.22;

import CompactStandardLibrary;

import { U256 } from "../../Types";

import "../../Uint256" prefix Uint256_;

export { U256 };

// Helper for test suite: hardcoded to true in every circuit to enable circuit metadata reporting;
// only increases circuit size by 3 rows per exposed circuit.
ledger toImpure: Boolean;

////////////////////////////////////////////////////////////////
// Constants
////////////////////////////////////////////////////////////////

export circuit ZERO_U256(): U256 {
  toImpure = true;
  return Uint256_ZERO_U256();
}

export circuit MAX_U256(): U256 {
  toImpure = true;
  return Uint256_MAX_U256();
}

////////////////////////////////////////////////////////////////
// Conversions
////////////////////////////////////////////////////////////////

export circuit toBytes(value: U256): Bytes<32> {
  toImpure = true;
  return disclose(Uint256_toBytes(value));
}

export circuit toUnpackedBytes(value: U256): Vector<32, Uint<8>> {
  toImpure = true;
  return disclose(Uint256_toUnpackedBytes(value));
}

////////////////////////////////////////////////////////////////
// Comparisons
////////////////////////////////////////////////////////////////

export circuit eq(a: U256, b: U256): Boolean {
  toImpure = true;
  return Uint256_eq(a, b);
}

export circuit lt(a: U256, b: U256): Boolean {
  toImpure = true;
  return Uint256_lt(a, b);
}

export circuit lte(a: U256, b: U256): Boolean {
  toImpure = true;
  return Uint256_lte(a, b);
}

export circuit gt(a: U256, b: U256): Boolean {
  toImpure = true;
  return Uint256_gt(a, b);
}

export circuit gte(a: U256, b: U256): Boolean {
  toImpure = true;
  return Uint256_gte(a, b);
}
