// SPDX-License-Identifier: MIT
// OpenZeppelin Compact Contracts v0.0.1-alpha.1 (access/AccessControl.compact)

pragma language_version >= 0.23;

// =============================================================================
//  SECURE PATTERN â€” witness-derived identity
// =============================================================================
//  Roles are keyed by a `UserPublicKey` DERIVED inside the ZK circuit from a
//  private witness secret (see the `Identity` module). `assertOnlyRole` takes
//  the caller's already-derived `UserPublicKey` and checks role membership
//  against it â€” it NEVER calls `ownPublicKey()`, which is prover-supplied and
//  bypassable for authorization. `grantRole` / `revokeRole` gate on the admin
//  role of the derived caller. The top-level contract computes the caller from
//  the witness and is the only thing that may call these circuits; the deployer
//  is granted `DEFAULT_ADMIN_ROLE` under their DERIVED key in the constructor.
// =============================================================================

/**
 * @module AccessControl
 * @description An unshielded AccessControl library.
 * This module provides a role-based access control mechanism, where roles can be used to
 * represent a set of permissions.
 *
 * Roles are referred to by their `Bytes<32>` identifier. These should be exposed
 * in the top-level contract and be unique. One way to achieve this is by
 * using `export sealed ledger` hash digests that are initialized in the top-level contract:
 *
 * ```typescript
 * import CompactStandardLibrary;
 * import "../modules/access/AccessControl" prefix AccessControl_;
 *
 * export sealed ledger MY_ROLE: Bytes<32>;
 *
 * constructor() {
 *  MY_ROLE = persistentHash<Bytes<32>>(pad(32, "MY_ROLE"));
 * }
 * ```
 *
 * To restrict access to a circuit, derive the caller from the witness secret in
 * the top-level contract and pass it to {assertOnlyRole}:
 *
 * ```typescript
 * circuit foo(): [] {
 *  const caller = disclose(Identity_deriveUserPublicKey(getUserSecret()));
 *  AccessControl_assertOnlyRole(MY_ROLE, caller);
 *  ...
 * }
 * ```
 *
 * Roles can be granted and revoked dynamically via the {grantRole} and
 * {revokeRole} circuits. Each role has an associated admin role, and only
 * accounts that have a role's admin role can call {grantRole} and {revokeRole}.
 *
 * By default, the admin role for all roles is `DEFAULT_ADMIN_ROLE`, which means
 * that only accounts with this role will be able to grant or revoke other
 * roles. More complex role relationships can be created by using
 * {_setRoleAdmin}.
 *
 * WARNING: The `DEFAULT_ADMIN_ROLE` is also its own admin: it has permission to
 * grant and revoke this role. Extra precautions should be taken to secure
 * accounts that have been granted it.
 *
 * @notice Accounts are identified by a witness-derived `UserPublicKey` rather
 * than an `Either<ZswapCoinPublicKey, ContractAddress>`. Because a
 * `UserPublicKey` is a derived 32-byte value (not a routable Zswap/contract
 * address), the contract-vs-user `_unsafe*` machinery of the address-based
 * design does not apply here and has been removed.
 *
 * @notice Missing Features and Improvements:
 *
 * - Role events
 * - An ERC165-like interface
 */
module AccessControl {
  import CompactStandardLibrary;
  import "../utils/Identity" prefix Identity_;

  /**
   * @description Mapping from a role identifier -> account -> its permissions.
   * @type {Map<Bytes<32>, Map<UserPublicKey, Boolean>>} _operatorRoles
   */
  export ledger _operatorRoles: Map<Bytes<32>, Map<Identity_UserPublicKey, Boolean>>;

  /**
   * @description Mapping from a role identifier to an admin role identifier.
   * @type {Map<Bytes<32>, Bytes<32>>} _adminRoles
   */
  export ledger _adminRoles: Map<Bytes<32>, Bytes<32>>;

  export ledger DEFAULT_ADMIN_ROLE: Bytes<32>;

  /**
   * @description Returns `true` if `account` has been granted `roleId`.
   * Takes a derived `UserPublicKey` only â€” no secret â€” so it is safe as a view.
   *
   * @param {Bytes<32>} roleId - The role identifier.
   * @param {UserPublicKey} account - The derived account key to query.
   * @return {Boolean} - Whether the account has the specified role.
    */
  export circuit hasRole(roleId: Bytes<32>, account: Identity_UserPublicKey): Boolean {
    if (_operatorRoles.member(disclose(roleId)) &&
        _operatorRoles.lookup(roleId).member(disclose(account))) {
      return _operatorRoles.lookup(roleId).lookup(disclose(account));
    } else {
      return false;
    }
  }

  /**
   * @description Reverts if the derived `caller` is missing `roleId`.
   *
   * @dev `caller` is the DERIVED identity of the transaction author, computed by
   * the top-level contract from the witness secret. Authorization holds because
   * only the secret holder can produce a `caller` that has been granted a role.
   *
   * Requirements:
   *
   * - `caller` must have `roleId`.
   *
   * @param {Bytes<32>} roleId - The role identifier.
   * @param {UserPublicKey} caller - The derived identity of the transaction author.
   * @return {[]} - Empty tuple.
   */
  export circuit assertOnlyRole(roleId: Bytes<32>, caller: Identity_UserPublicKey): [] {
    _checkRole(roleId, caller);
  }

  /**
   * @description Reverts if `account` is missing `roleId`.
   *
   * Requirements:
   *
   * - `account` must have `roleId`.
   *
   * @param {Bytes<32>} roleId - The role identifier.
   * @param {UserPublicKey} account - The derived account key to query.
   * @return {[]} - Empty tuple.
   */
  export circuit _checkRole(roleId: Bytes<32>, account: Identity_UserPublicKey): [] {
    assert(hasRole(roleId, account), "AccessControl: unauthorized account");
  }

  /**
   * @description Returns the admin role that controls `roleId` or
   * a byte array with all zero bytes if `roleId` doesn't exist. See {grantRole} and {revokeRole}.
   *
   * To change a role's admin use {_setRoleAdmin}.
   *
   * @param {Bytes<32>} roleId - The role identifier.
   * @return {Bytes<32>} roleAdmin - The admin role that controls `roleId`.
   */
  export circuit getRoleAdmin(roleId: Bytes<32>): Bytes<32> {
    if (_adminRoles.member(disclose(roleId))) {
      return _adminRoles.lookup(disclose(roleId));
    }
    return default<Bytes<32>>;
  }

  /**
   * @description Grants `roleId` to `account`.
   *
   * @dev `caller` is the DERIVED identity of the transaction author; it must
   * hold `roleId`'s admin role.
   *
   * Requirements:
   *
   * - `caller` must have `roleId`'s admin role.
   *
   * @param {Bytes<32>} roleId - The role identifier.
   * @param {UserPublicKey} account - The derived key to grant the role to.
   * @param {UserPublicKey} caller - The derived identity of the transaction author.
   * @return {[]} - Empty tuple.
   */
  export circuit grantRole(
                   roleId: Bytes<32>,
                   account: Identity_UserPublicKey,
                   caller: Identity_UserPublicKey
                   ): [] {
    assertOnlyRole(getRoleAdmin(roleId), caller);
    _grantRole(roleId, account);
  }

  /**
   * @description Revokes `roleId` from `account`.
   *
   * @dev `caller` is the DERIVED identity of the transaction author; it must
   * hold `roleId`'s admin role.
   *
   * Requirements:
   *
   * - `caller` must have `roleId`'s admin role.
   *
   * @param {Bytes<32>} roleId - The role identifier.
   * @param {UserPublicKey} account - The derived key to revoke the role from.
   * @param {UserPublicKey} caller - The derived identity of the transaction author.
   * @return {[]} - Empty tuple.
   */
  export circuit revokeRole(
                   roleId: Bytes<32>,
                   account: Identity_UserPublicKey,
                   caller: Identity_UserPublicKey
                   ): [] {
    assertOnlyRole(getRoleAdmin(roleId), caller);
    _revokeRole(roleId, account);
  }

  /**
   * @description Revokes `roleId` from the calling account.
   *
   * @notice Roles are often managed via {grantRole} and {revokeRole}: this circuit's
   * purpose is to provide a mechanism for accounts to lose their privileges
   * if they are compromised.
   *
   * @dev `caller` is the DERIVED identity of the transaction author. Because the
   * caller is derived from the witness secret, the `callerConfirmation` of the
   * address-based design is unnecessary â€” only the secret holder can produce
   * their own derived key.
   *
   * @param {Bytes<32>} roleId - The role identifier.
   * @param {UserPublicKey} caller - The derived identity of the transaction author.
   * @return {[]} - Empty tuple.
   */
  export circuit renounceRole(roleId: Bytes<32>, caller: Identity_UserPublicKey): [] {
    _revokeRole(roleId, caller);
  }

  /**
   * @description Sets `adminRole` as `roleId`'s admin role.
   *
   * @param {Bytes<32>} roleId - The role identifier.
   * @param {Bytes<32>} adminRole - The admin role identifier.
   * @return {[]} - Empty tuple.
   */
  export circuit _setRoleAdmin(roleId: Bytes<32>, adminRole: Bytes<32>): [] {
    _adminRoles.insert(disclose(roleId), disclose(adminRole));
  }

  /**
   * @description Attempts to grant `roleId` to `account` and returns a boolean indicating if `roleId` was granted.
   * Internal circuit without access restriction.
   *
   * @param {Bytes<32>} roleId - The role identifier.
   * @param {UserPublicKey} account - The derived account key.
   * @return {Boolean} roleGranted - A boolean indicating if `roleId` was granted.
   */
  export circuit _grantRole(roleId: Bytes<32>, account: Identity_UserPublicKey): Boolean {
    if (hasRole(roleId, account)) {
      return false;
    }

    if (!_operatorRoles.member(disclose(roleId))) {
      _operatorRoles.insert(disclose(roleId), default<Map<Identity_UserPublicKey, Boolean>>);
    }

    _operatorRoles.lookup(roleId).insert(disclose(account), true);
    return true;
  }

  /**
   * @description Attempts to revoke `roleId` from `account` and returns a boolean indicating if `roleId` was revoked.
   * Internal circuit without access restriction.
   *
   * @param {Bytes<32>} roleId - The role identifier.
   * @param {UserPublicKey} account - The derived account key.
   * @return {Boolean} roleRevoked - A boolean indicating if `roleId` was revoked.
   */
  export circuit _revokeRole(roleId: Bytes<32>, account: Identity_UserPublicKey): Boolean {
    if (!hasRole(roleId, account)) {
      return false;
    }

    _operatorRoles.lookup(roleId).insert(disclose(account), false);
    return true;
  }
}
