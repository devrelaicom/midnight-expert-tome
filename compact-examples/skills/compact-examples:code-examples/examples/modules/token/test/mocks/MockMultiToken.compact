pragma language_version >= 0.23;

// SECURE PATTERN — witness-derived identity
//
// This mock composes the MultiToken module for the upstream OpenZeppelin test
// harness. It mirrors the production composing contract (MultiTokenTwoTypes):
// the witness `getUserSecret` is the SOLE source of caller identity, the admin
// is pinned at deploy, and identity-sensitive operations compute the caller via
// `deriveUserPublicKey(getUserSecret())` rather than `ownPublicKey()`.
//
// In addition to the safe wrappers, this mock re-exports the module's
// unauthenticated building blocks (`_mint`/`_burn`/`_transfer`/
// `_setApprovalForAll`) so tests can set up arbitrary state directly. These are
// test-only conveniences and are intentionally NOT exported by the production
// composing contract.

import CompactStandardLibrary;

import "../../MultiToken" prefix MultiToken_;

export { MultiToken_UserSecretKey, MultiToken_UserPublicKey, MultiToken_AdminPublicKey, };

export { MultiToken_deriveUserPublicKey, MultiToken_deriveAdminPublicKey };

export { Maybe };

// Test-only visibility into module ledger state.
export { MultiToken__balances, MultiToken__operatorApprovals, MultiToken__uri, };

// The identity witness. Each (simulated) caller carries their own 32-byte
// secret; switching the simulated caller means swapping this secret.
witness getUserSecret(): MultiToken_UserSecretKey;

// The admin's derived public key, pinned at deploy time.
export ledger contractAdmin: MultiToken_AdminPublicKey;

/**
 * @description `_uri` is a `Maybe` type for testing.
 * If `_uri` is provided, initialize the contract with that value.
 * Otherwise, the contract will not initialize and we can test the contract
 * when it is not initialized properly.
 */
constructor(_uri: Maybe<Opaque<"string">>) {
  if (disclose(_uri.is_some)) {
    MultiToken_initialize(_uri.value);
  }
  contractAdmin = disclose(MultiToken_deriveAdminPublicKey(getUserSecret()));
}

export circuit initialize(_uri: Opaque<"string">): [] {
  return MultiToken_initialize(_uri);
}

export circuit uri(id: Uint<128>): Opaque<"string"> {
  return MultiToken_uri(id);
}

// ---- read-only views --------------------------------------------------------

export circuit balanceOf(account: MultiToken_UserPublicKey, id: Uint<128>): Uint<128> {
  return MultiToken_balanceOf(account, id);
}

export circuit isApprovedForAll(
                 account: MultiToken_UserPublicKey,
                 operator: MultiToken_UserPublicKey
                 ): Boolean {
  return MultiToken_isApprovedForAll(account, operator);
}

// ---- safe (witness-derived) wrappers ----------------------------------------

export circuit setApprovalForAll(operator: MultiToken_UserPublicKey, approved: Boolean): [] {
  const caller = disclose(MultiToken_deriveUserPublicKey(getUserSecret()));
  MultiToken_setApprovalForAll(caller, operator, approved);
}

export circuit transfer(to: MultiToken_UserPublicKey, id: Uint<128>, value: Uint<128>): [] {
  const caller = disclose(MultiToken_deriveUserPublicKey(getUserSecret()));
  MultiToken_transferFrom(caller, caller, to, id, value);
}

export circuit transferFromAuthorized(
                 fromAddress: MultiToken_UserPublicKey,
                 to: MultiToken_UserPublicKey,
                 id: Uint<128>,
                 value: Uint<128>
                 ): [] {
  const caller = disclose(MultiToken_deriveUserPublicKey(getUserSecret()));
  MultiToken_transferFrom(caller, fromAddress, to, id, value);
}

// ---- test-only unauthenticated building blocks ------------------------------

export circuit _transfer(
                 fromAddress: MultiToken_UserPublicKey,
                 to: MultiToken_UserPublicKey,
                 id: Uint<128>,
                 value: Uint<128>
                 ): [] {
  return MultiToken__transfer(fromAddress, to, id, value);
}

export circuit _setURI(newURI: Opaque<"string">): [] {
  return MultiToken__setURI(newURI);
}

export circuit _mint(to: MultiToken_UserPublicKey, id: Uint<128>, value: Uint<128>): [] {
  return MultiToken__mint(to, id, value);
}

export circuit _burn(fromAddress: MultiToken_UserPublicKey, id: Uint<128>, value: Uint<128>): [] {
  return MultiToken__burn(fromAddress, id, value);
}

export circuit _setApprovalForAll(
                 owner: MultiToken_UserPublicKey,
                 operator: MultiToken_UserPublicKey,
                 approved: Boolean
                 ): [] {
  return MultiToken__setApprovalForAll(owner, operator, approved);
}
