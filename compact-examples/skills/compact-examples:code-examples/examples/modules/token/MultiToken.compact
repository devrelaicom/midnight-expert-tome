// SPDX-License-Identifier: MIT
// OpenZeppelin Compact Contracts v0.0.1-alpha.1 (token/MultiToken.compact)

pragma language_version >= 0.22;

// =============================================================================
//  SECURE PATTERN — witness-derived identity
// =============================================================================
//  Caller identity is derived INSIDE the circuit from a private witness secret
//  via domain-separated `persistentHash` (see `deriveUserPublicKey` /
//  `deriveAdminPublicKey`). `ownPublicKey()` is intentionally NOT used for
//  authorization: it returns a prover-supplied value with no binding to the
//  transaction signer, so any check built on it is bypassable. Identity-bearing
//  circuits here take the caller's DERIVED `UserPublicKey` as an explicit
//  parameter; the witness lives in the top-level composing contract, which
//  computes that parameter and never lets a caller pass an arbitrary identity.
//  The admin is pinned at deploy in the top-level contract.
//
//  Accounts are represented as a flat `UserPublicKey { bytes: Bytes<32> }`
//  derived from the holder's secret, replacing the original
//  `Either<ZswapCoinPublicKey, ContractAddress>`. Because there is no longer a
//  key-vs-contract distinction, the "unsafe transfer to a contract address"
//  notion does not apply; the `_unsafe*` circuits are retained as aliases of
//  their checked counterparts so existing call sites keep compiling, and the
//  only address guard that remains is the zero-key check.
// =============================================================================

/**
 * @module MultiToken
 * @description An unshielded MultiToken library. This library is inspired by
 * ERC1155. Many aspects of the EIP-1155 spec cannot be implemented in Compact;
 * therefore, the MultiToken module should be treated as an approximation of
 * the ERC1155 standard and not necessarily a compliant implementation.
 *
 * @notice One notable difference regarding this implementation and the EIP1155 spec
 * consists of the token size. Uint<128> is used as the token size because Uint<256>
 * cannot be supported. This is true for both token IDs and for amounts.
 * This is due to encoding limits on the midnight circuit backend:
 * https://github.com/midnightntwrk/compactc/issues/929
 *
 * @notice Some features defined in th EIP1155 spec are NOT included.
 * Such features include:
 *
 * 1. Batch mint, burn, transfer - Without support for dynamic arrays,
 * batching transfers is difficult to do without a hacky solution.
 * For instance, we could change the `to` and `fromAddress` parameters to be
 * vectors. This would change the signature and would be both difficult
 * to use and easy to misuse.
 *
 * 2. Querying batched balances - This can be somewhat supported.
 * The issue, without dynamic arrays, is that the module circuit must use
 * Vector<n> for accounts and ids; therefore, the implementing contract must
 * explicitly define the number of balances to query in the circuit i.e.
 *
 * balanceOfBatch_10(
 *    accounts: Vector<10, UserPublicKey>,
 *    ids: Vector<10, Uint<128>>
 * ): Vector<10, Uint<128>>
 *
 * Since this module does not offer mint or transfer batching,
 * balance batching is also not included at this time.
 *
 * 3. Introspection - Compact currently cannot support contract-to-contract
 * queries for introspection. ERC165 (or an equivalent thereof) is NOT
 * included in the contract.
 *
 * 4. Safe transfers - The lack of an introspection mechanism means
 * safe transfers of any kind can not be supported.
 *
 * Due to the vast incompatibilities with the EIP1155 spec, it is our
 * opinion that this implementation should not be called ERC1155 at this time
 * as this would be both very confusing and misleading. This may change as more
 * features become available. The list of missing features is as follows:
 *
 * - Full uint256 support.
 * - Events.
 * - Dynamic arrays.
 * - Introspection.
 * - Contract-to-contract calls for acceptance callback.
 */
module MultiToken {
  import CompactStandardLibrary;
  import "../security/Initializable" prefix Initializable_;

  // Identity types. Every account is a 32-byte value DERIVED from a private
  // witness secret via a domain-separated persistentHash (computed in the
  // top-level contract) — never a raw, prover-supplied public key.
  export struct UserSecretKey {
    bytes: Bytes<32>;
  }
  export struct UserPublicKey {
    bytes: Bytes<32>;
  }
  export struct AdminPublicKey {
    bytes: Bytes<32>;
  }

  // Per-user identity. Derived from the holder's secret; a caller can only act
  // as the identity whose secret they hold. Used as the balance/approval key.
  export pure circuit deriveUserPublicKey(sk: UserSecretKey): UserPublicKey {
    return UserPublicKey { bytes: persistentHash<Vector<2, Bytes<32>>>(
                                    [pad(32, "multitoken:user:pk:v1"), sk.bytes]
                                    ) };
  }

  // Admin identity. Domain-separated from the user derivation so the same secret
  // yields a distinct admin key. The deployer's `deriveAdminPublicKey(secret)`
  // is frozen into `contractAdmin` at deploy.
  export pure circuit deriveAdminPublicKey(sk: UserSecretKey): AdminPublicKey {
    return AdminPublicKey { bytes: persistentHash<Vector<2, Bytes<32>>>(
                                     [pad(32, "multitoken:admin:pk:v1"), sk.bytes]
                                     ) };
  }

  /**
   * @description Mapping from token ID to account balances.
   * @type {Uint<128>} id - The token identifier.
   * @type {UserPublicKey} account - The derived account key.
   * @type {Uint<128>} balance - The balance of the account for the token.
   * @type {Map<id, Map<account, balance>>}
   * @type {Map<Uint<128>, Map<UserPublicKey, Uint<128>>>} _balances
   */
  export ledger _balances: Map<Uint<128>, Map<UserPublicKey, Uint<128>>>;

  /**
   * @description Mapping from account to operator approvals.
   * @type {UserPublicKey} account - The derived account key.
   * @type {UserPublicKey} operator - The derived operator key.
   * @type {Boolean} approved - The approval status of the operator for the account.
   * @type {Map<account, Map<operator, approved>>}
   * @type {Map<UserPublicKey, Map<UserPublicKey, Boolean>>}
   */
  export ledger _operatorApprovals: Map<UserPublicKey, Map<UserPublicKey, Boolean>>;

  /**
   * @description Base URI for computing token URIs.
   * Used as the URI for all token types by relying on ID substitution, e.g. https://token-cdn-domain/{id}.json
   * @type {Opaque<"string">} _uri - The base URI for all token URIs.
   */
  export ledger _uri: Opaque<"string">;

  /**
   * @description Initializes the contract by setting the base URI for all tokens.
   *
   * Requirements:
   *
   * - Must be called in the contract's constructor.
   *
   * @param {Opaque<"string">} uri_ - The base URI for all token URIs.
   * @return {[]} - Empty tuple.
   */
  export circuit initialize(uri_: Opaque<"string">): [] {
    Initializable_initialize();
    _setURI(uri_);
  }

  /**
   * @description This implementation returns the same URI for *all* token types. It relies
   * on the token type ID substitution mechanism defined in the EIP:
   * https://eips.ethereum.org/EIPS/eip-1155#metadata.
   * Clients calling this function must replace the `\{id\}` substring with the
   * actual token type ID.
   *
   * Requirements:
   *
   * - Contract is initialized.
   *
   * @param {Uint<128>} id - The token identifier to query.
   * return {Opaque<"string">} - The base URI for all tokens.
   */
  export circuit uri(id: Uint<128>): Opaque<"string"> {
    Initializable_assertInitialized();

    return _uri;
  }

  /**
   * @description Returns the amount of `id` tokens owned by `account`.
   *
   * Requirements:
   *
   * - Contract is initialized.
   *
   * @param {UserPublicKey} account - The account balance to query.
   * @param {Uint<128>} id - The token identifier to query.
   * return {Uint<128>} - The quantity of `id` tokens that `account` owns.
   */
  export circuit balanceOf(account: UserPublicKey, id: Uint<128>): Uint<128> {
    Initializable_assertInitialized();

    if (!_balances.member(disclose(id)) || !_balances.lookup(id).member(disclose(account))) {
      return 0;
    }
    return _balances.lookup(id).lookup(disclose(account));
  }

  /**
   * @description Enables or disables approval for `operator` to manage all of the caller's assets.
   *
   * @notice `caller` is the DERIVED identity computed by the top-level contract
   * from the witness secret — it is the proven identity of the transaction author.
   *
   * Requirements:
   *
   * - Contract is initialized.
   * - `operator` is not the zero address.
   *
   * @param {UserPublicKey} caller - The derived identity of the transaction author.
   * @param {UserPublicKey} operator - The derived key whose approval is set for the caller's assets.
   * @param {Boolean} approved - The boolean value determining if the operator may or may not handle the
   * caller's assets.
   * @return {[]} - Empty tuple.
   */
  export circuit setApprovalForAll(
                   caller: UserPublicKey,
                   operator: UserPublicKey,
                   approved: Boolean
                   ): [] {
    Initializable_assertInitialized();

    _setApprovalForAll(caller, operator, approved);
  }

  /**
   * @description Queries if `operator` is an authorized operator for `account`.
   *
   * Requirements:
   *
   * - Contract is initialized.
   *
   * @param {UserPublicKey} account - The queried possessor of assets.
   * @param {UserPublicKey} operator - The queried handler of `account`'s assets.
   * @return {Boolean} - Whether or not `operator` has permission to handle `account`'s assets.
   */
  export circuit isApprovedForAll(account: UserPublicKey, operator: UserPublicKey): Boolean {
    Initializable_assertInitialized();

    if (!_operatorApprovals.member(disclose(account)) ||
        !_operatorApprovals.lookup(account).member(disclose(operator))) {
      return false;
    }

    return _operatorApprovals.lookup(account).lookup(disclose(operator));
  }

  /**
   * @description Transfers ownership of `value` amount of `id` tokens from `fromAddress` to `to`.
   * The caller must be `fromAddress` or approved to transfer on their behalf.
   *
   * @notice `caller` is the DERIVED identity of the transaction author. Because
   * accounts are flat derived keys, there is no contract-address recipient to
   * guard against; this circuit is equivalent to the former `_unsafeTransferFrom`.
   *
   * @extensibility External circuit. Can be used directly by consumers of this module.
   * See **Extensibility** documentation for usage patterns.
   *
   * Requirements:
   *
   * - Contract is initialized.
   * - `to` is not the zero address.
   * - `fromAddress` is not the zero address.
   * - Caller must be `fromAddress` or approved via `setApprovalForAll`.
   * - `fromAddress` must have an `id` balance of at least `value`.
   *
   * @param {UserPublicKey} caller - The derived identity of the transaction author.
   * @param {UserPublicKey} fromAddress - The owner from which the transfer originates.
   * @param {UserPublicKey} to - The recipient of the transferred assets.
   * @param {Uint<128>} id - The unique identifier of the asset type.
   * @param {Uint<128>} value - The quantity of `id` tokens to transfer.
   * @return {[]} - Empty tuple.
   */
  export circuit transferFrom(
                   caller: UserPublicKey,
                   fromAddress: UserPublicKey,
                   to: UserPublicKey,
                   id: Uint<128>,
                   value: Uint<128>
                   ): [] {
    Initializable_assertInitialized();

    if (disclose(fromAddress) != caller) {
      assert(isApprovedForAll(fromAddress, caller), "MultiToken: unauthorized operator");
    }

    _transfer(fromAddress, to, id, value);
  }

  /**
   * @description Alias of `transferFrom`. The original module distinguished a
   * "safe" transfer (rejecting contract-address recipients) from an "unsafe"
   * one; with flat derived keys there is no such distinction, so this is kept
   * only for source compatibility.
   *
   * @param {UserPublicKey} caller - The derived identity of the transaction author.
   * @param {UserPublicKey} fromAddress - The owner from which the transfer originates.
   * @param {UserPublicKey} to - The recipient of the transferred assets.
   * @param {Uint<128>} id - The unique identifier of the asset type.
   * @param {Uint<128>} value - The quantity of `id` tokens to transfer.
   * @return {[]} - Empty tuple.
   */
  export circuit _unsafeTransferFrom(
                   caller: UserPublicKey,
                   fromAddress: UserPublicKey,
                   to: UserPublicKey,
                   id: Uint<128>,
                   value: Uint<128>
                   ): [] {
    transferFrom(caller, fromAddress, to, id, value);
  }

  /**
   * @description Transfers ownership of `value` amount of `id` tokens from `fromAddress` to `to`.
   * Does not impose restrictions on the caller, making it suitable for composition
   * in higher-level contract logic.
   *
   * Requirements:
   *
   * - Contract is initialized.
   * - `to` is not the zero address.
   * - `fromAddress` is not the zero address.
   * - `fromAddress` must have an `id` balance of at least `value`.
   *
   * @param {UserPublicKey} fromAddress - The owner from which the transfer originates.
   * @param {UserPublicKey} to - The recipient of the transferred assets.
   * @param {Uint<128>} id - The unique identifier of the asset type.
   * @param {Uint<128>} value - The quantity of `id` tokens to transfer.
   * @return {[]} - Empty tuple.
   */
  export circuit _transfer(
                   fromAddress: UserPublicKey,
                   to: UserPublicKey,
                   id: Uint<128>,
                   value: Uint<128>
                   ): [] {
    Initializable_assertInitialized();

    assert(fromAddress != default<UserPublicKey>, "MultiToken: invalid sender");
    assert(to != default<UserPublicKey>, "MultiToken: invalid receiver");
    _update(fromAddress, to, id, value);
  }

  /**
   * @description Alias of `_transfer`. Retained only for source compatibility
   * with the former "unsafe" variant; flat derived keys make the distinction
   * meaningless.
   *
   * @param {UserPublicKey} fromAddress - The owner from which the transfer originates.
   * @param {UserPublicKey} to - The recipient of the transferred assets.
   * @param {Uint<128>} id - The unique identifier of the asset type.
   * @param {Uint<128>} value - The quantity of `id` tokens to transfer.
   * @return {[]} - Empty tuple.
   */
  export circuit _unsafeTransfer(
                   fromAddress: UserPublicKey,
                   to: UserPublicKey,
                   id: Uint<128>,
                   value: Uint<128>
                   ): [] {
    _transfer(fromAddress, to, id, value);
  }

  /**
   * @description Transfers a value amount of tokens of type id from fromAddress to to.
   * This circuit will mint (or burn) if `fromAddress` (or `to`) is the zero address.
   *
   * Requirements:
   *
   * - Contract is initialized.
   * - If `fromAddress` is not zero, the balance of `id` of `fromAddress` must be >= `value`.
   *
   * @param {UserPublicKey} fromAddress - The origin of the transfer.
   * @param {UserPublicKey} to - The destination of the transfer.
   * @param {Uint<128>} id - The unique identifier of the asset type.
   * @param {Uint<128>} value - The quantity of `id` tokens to transfer.
   * @return {[]} - Empty tuple.
   */
  circuit _update(fromAddress: UserPublicKey,
                  to: UserPublicKey,
                  id: Uint<128>,
                  value: Uint<128>
                  ): [] {
    Initializable_assertInitialized();

    if (disclose(fromAddress) != default<UserPublicKey>) {
      const fromBalance = balanceOf(fromAddress, id);
      assert(fromBalance >= value, "MultiToken: insufficient balance");
      // overflow not possible
      const newBalance = fromBalance - value;
      _balances.lookup(id).insert(disclose(fromAddress), disclose(newBalance));
    }

    if (disclose(to) != default<UserPublicKey>) {
      // id not initialized
      if (!_balances.member(disclose(id))) {
        _balances.insert(disclose(id), default<Map<UserPublicKey, Uint<128>>>);
        _balances.lookup(id).insert(disclose(to), disclose(value as Uint<128>));
      } else {
        const toBalance = balanceOf(to, id), MAX_UINT128 = 340282366920938463463374607431768211455;
        assert(MAX_UINT128 - toBalance >= value, "MultiToken: arithmetic overflow");
        _balances.lookup(id).insert(disclose(to), disclose(toBalance + value as Uint<128>));
      }
    }
  }

  /**
   * @description Sets a new URI for all token types, by relying on the token type ID
   * substitution mechanism defined in the MultiToken standard.
   * See https://eips.ethereum.org/EIPS/eip-1155#metadata.
   *
   * @notice By this mechanism, any occurrence of the `\{id\}` substring in either the
   * URI or any of the values in the JSON file at said URI will be replaced by
   * clients with the token type ID.
   *
   * Requirements:
   *
   * - Contract is initialized.
   *
   * @param {Opaque<"string">} newURI - The new base URI for all tokens.
   * @return {[]} - Empty tuple.
   */
  export circuit _setURI(newURI: Opaque<"string">): [] {
    Initializable_assertInitialized();

    _uri = disclose(newURI);
  }

  /**
   * @description Creates a `value` amount of tokens of type `id`, and assigns them to `to`.
   * Authorization is enforced by the top-level admin wrapper, not here.
   *
   * Requirements:
   *
   * - Contract is initialized.
   * - `to` is not the zero address.
   *
   * @param {UserPublicKey} to - The recipient of the minted tokens.
   * @param {Uint<128>} id - The unique identifier for the token type.
   * @param {Uint<128>} value - The quantity of `id` tokens that are minted to `to`.
   * @return {[]} - Empty tuple.
   */
  export circuit _mint(to: UserPublicKey, id: Uint<128>, value: Uint<128>): [] {
    Initializable_assertInitialized();

    assert(to != default<UserPublicKey>, "MultiToken: invalid receiver");
    _update(default<UserPublicKey>, to, id, value);
  }

  /**
   * @description Alias of `_mint`. Retained only for source compatibility with
   * the former "unsafe" variant; flat derived keys make the distinction
   * meaningless.
   *
   * @param {UserPublicKey} to - The recipient of the minted tokens.
   * @param {Uint<128>} id - The unique identifier for the token type.
   * @param {Uint<128>} value - The quantity of `id` tokens that are minted to `to`.
   * @return {[]} - Empty tuple.
   */
  export circuit _unsafeMint(to: UserPublicKey, id: Uint<128>, value: Uint<128>): [] {
    _mint(to, id, value);
  }

  /**
   * @description Destroys a `value` amount of tokens of type `id` from `fromAddress`.
   * Authorization is enforced by the top-level admin wrapper, not here.
   *
   * Requirements:
   *
   * - Contract is initialized.
   * - `fromAddress` is not the zero address.
   * - `fromAddress` must have an `id` balance of at least `value`.
   *
   * @param {UserPublicKey} fromAddress - The owner whose tokens will be destroyed.
   * @param {Uint<128>} id - The unique identifier of the token type.
   * @param {Uint<128>} value - The quantity of `id` tokens that will be destroyed from `fromAddress`.
   * @return {[]} - Empty tuple.
   */
  export circuit _burn(fromAddress: UserPublicKey, id: Uint<128>, value: Uint<128>): [] {
    Initializable_assertInitialized();

    assert(fromAddress != default<UserPublicKey>, "MultiToken: invalid sender");
    _update(fromAddress, default<UserPublicKey>, id, value);
  }

  /**
   * @description Enables or disables approval for `operator` to manage all of `owner`'s assets.
   *
   * @notice This circuit does not check for access permissions but can be useful as a building block
   * for more complex contract logic.
   *
   * Requirements:
   *
   * - Contract is initialized.
   * - `operator` is not the zero address.
   *
   * @param {UserPublicKey} owner - The derived key of the target owner.
   * @param {UserPublicKey} operator - The derived key whose approval is set for the
   * `owner`'s assets.
   * @param {Boolean} approved - The boolean value determining if the operator may or may not handle the
   * `owner`'s assets.
   * @return {[]} - Empty tuple.
   */
  export circuit _setApprovalForAll(
                   owner: UserPublicKey,
                   operator: UserPublicKey,
                   approved: Boolean
                   ): [] {
    Initializable_assertInitialized();

    assert(operator != default<UserPublicKey>, "MultiToken: invalid operator");
    if (!_operatorApprovals.member(disclose(owner))) {
      _operatorApprovals.insert(disclose(owner), default<Map<UserPublicKey, Boolean>>);
    }

    _operatorApprovals.lookup(owner).insert(disclose(operator), disclose(approved));
  }
}
